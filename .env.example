# Local dev: copy to .env.local and fill in your keys
# Railway:  add these in Project → Variables (no .env file needed)
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=   # optional — enables short-lived scoped STT tokens
PORT=3030              # Railway sets PORT automatically — do not override
ALLOWED_ORIGIN=*       # set to your Railway URL in production
